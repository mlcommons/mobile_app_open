"""
Stub repository rule for @local_config_python and @local_execution_config_python.

Generates valid py_runtime targets using interpreter_path (Bazel 7 compatible).
Declared before tf_workspace3() so these stubs win over the broken ones
generated by python_configure.bzl which uses the old interpreter= attribute.
"""

def _local_config_python_stub_impl(ctx):
    ctx.file("BUILD", """
load("@bazel_tools//tools/python:toolchain.bzl", "py_runtime_pair")

py_runtime(
    name = "py2_runtime",
    interpreter_path = "/usr/bin/python3",
    python_version = "PY2",
    visibility = ["//visibility:public"],
)

py_runtime(
    name = "py3_runtime",
    interpreter_path = "/usr/bin/python3",
    python_version = "PY3",
    visibility = ["//visibility:public"],
)

py_runtime_pair(
    name = "py_runtime_pair",
    py2_runtime = ":py2_runtime",
    py3_runtime = ":py3_runtime",
)

toolchain(
    name = "py_toolchain",
    toolchain = ":py_runtime_pair",
    toolchain_type = "@bazel_tools//tools/python:toolchain_type",
    visibility = ["//visibility:public"],
)
""")

local_config_python_stub = repository_rule(
    implementation = _local_config_python_stub_impl,
    local = True,
)