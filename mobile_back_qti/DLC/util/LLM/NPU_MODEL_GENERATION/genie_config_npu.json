{
  "dialog": {
    "version": 1,
    "type": "basic",
    "stop-sequence": [""],
    "max-num-tokens": 512,
    "engine": {
      "version": 1,
      "n-threads": 3,
      "backend": {
        "version": 1,
        "type": "QnnHtp",
        "QnnHtp": {
          "version": 1,
          "spill-fill-bufsize": 0,
          "use-mmap": false,
          "mmap-budget": 0,
          "poll": false,
          "pos-id-dim": 64,
          "cpu-mask": "0xe0",
          "kv-dim": 128,
          "rope-theta": 500000
        },
        "extensions": "{{MODEL_DIR}}/htpBackendExtConfig.json"
      },
      "model": {
        "version": 1,
        "type": "binary",
        "binary": {
          "version": 1,
          "ctx-bins": [
            "{{MODEL_DIR}}/llama3_npu_1_of_6.bin",
            "{{MODEL_DIR}}/llama3_npu_2_of_6.bin",
            "{{MODEL_DIR}}/llama3_npu_3_of_6.bin",
            "{{MODEL_DIR}}/llama3_npu_4_of_6.bin",
            "{{MODEL_DIR}}/llama3_npu_5_of_6.bin",
            "{{MODEL_DIR}}/llama3_npu_6_of_6.bin"
          ]
        }
      }
    },
    "context": {
      "version": 1,
      "size": 4096,
      "n-vocab": 128256,
      "bos-token": -1,
      "eos-token": [128001, 128008, 128009]
    },
    "sampler": {
      "version": 1,
      "seed": 100,
      "temp": 1.0,
      "top-k": 1,
      "top-p": 0.95,
      "greedy": true
    },
    "tokenizer": {
      "version": 1,
      "path": "{{MODEL_DIR}}/tokenizer.json"
    }
  }
}
